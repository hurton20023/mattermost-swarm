# Mattermost Configuration

# Domain or IP of the service
DOMAIN=192.168.1.154

# Timezone
TZ=UTC

# Restart policy for containers
RESTART_POLICY=unless-stopped

# Postgres settings
POSTGRES_IMAGE_TAG=13-alpine
POSTGRES_USER=mmuser
POSTGRES_PASSWORD=most-secret-password-change-me
POSTGRES_DB=mattermost
POSTGRES_DATA_PATH=./volumes/db/data

# Mattermost settings
MATTERMOST_IMAGE=mattermost-team-edition
MATTERMOST_IMAGE_TAG=9.5.2
MATTERMOST_CONFIG_PATH=./volumes/app/config
MATTERMOST_DATA_PATH=./volumes/app/data
MATTERMOST_LOGS_PATH=./volumes/app/logs
MATTERMOST_PLUGINS_PATH=./volumes/app/plugins
MATTERMOST_CLIENT_PLUGINS_PATH=./volumes/app/client/plugins
MATTERMOST_BLEVE_INDEXES_PATH=./volumes/app/bleve-indexes

# Port mapping (Swarm/NodePort range friendly)
APP_PORT=31201

# Mattermost Environment Variables
MM_SQLSETTINGS_DRIVERNAME=postgres
MM_SQLSETTINGS_DATASOURCE=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?sslmode=disable&connect_timeout=10
MM_SERVICESETTINGS_SITEURL=http://${DOMAIN}:${APP_PORT}

# CoTURN (ICE/STUN/TURN) settings
TURN_USER=mmuser
TURN_PASSWORD=mmuser_turn_password_change_me
TURN_REALM=192.168.1.154
TURN_EXTERNAL_IP=192.168.1.154
# CoTURN Listening port
TURN_PORT=3478
# CoTURN Relay ports range starting from 31202
TURN_MIN_PORT=31202
TURN_MAX_PORT=31252
